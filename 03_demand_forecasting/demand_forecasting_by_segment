    "\n",
    "# ================================\n",
    "# COMPARACIÓN REAL VS PRED\n",
    "# ================================\n",
    "\n",
    "comparison = test.copy()\n",
    "comparison[\"forecast\"] = pred[\"yhat\"].values\n",
    "\n",
    "print(comparison)\n",
    "\n",
    "# ================================\n",
